# Copy this file to .env on each machine. Do not commit .env.

# Runtime
TZ=Asia/Shanghai
PORT=8765

# SQLite database path inside Docker containers.
DB_PATH=/app/data/market_review.db

# Scheduler
DAILY_UPDATE_AT=17:30
PREMARKET_UPDATE_AT=08:30
DAILY_KLINE_LIMIT=30
DAILY_UPDATE_FORCE=0

# Quantzz data source
QUANTZZ_API_BASE=https://api.zizizaizai.com

# Prefer token file for long-running services.
QUANTZZ_TOKEN_FILE=/app/config/quantzz_token.json

# Optional: set token directly through environment.
QUANTZZ_TOKEN=

# Optional: allow the plate rotation collector to log in when no token is present.
QUANTZZ_EMAIL=
QUANTZZ_PASSWORD=
